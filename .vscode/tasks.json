{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run app.py",
            "type": "shell",
            "command": ".venv/bin/ampy",
            "args": [
                "--port",
                "/dev/ttyACM0",
                "run",
                "app.py"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}